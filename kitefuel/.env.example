# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by the backend (SQLAlchemy / Alembic).
# Default value is for host-machine development after copying to .env.
# When running fully inside Docker, replace "localhost" with the service name "postgres".
DATABASE_URL=postgresql://postgres:kitefuel@localhost:5432/kitefuel

# ── Local Blockchain (Anvil) ──────────────────────────────────────────────────
# JSON-RPC endpoint for the local Foundry Anvil devnet.
# Default value is for host-machine development after copying to .env.
# When running fully inside Docker, replace "localhost" with the service name "anvil".
ANVIL_RPC_URL=http://localhost:8545

# ── Backend Signer ────────────────────────────────────────────────────────────
# Private key used by the backend to sign on-chain transactions.
# Leave empty and fill in before starting the service.
# NEVER use a real funded key here in development.
BACKEND_SIGNER_PRIVATE_KEY=

# ── Smart Contract ────────────────────────────────────────────────────────────
# Deployed address of the KiteFuel escrow contract.
# Populate after running the deploy script against Anvil or a testnet.
CONTRACT_ADDRESS=

# ── Frontend ──────────────────────────────────────────────────────────────────
# Base URL the Vite frontend uses to reach the FastAPI backend.
# Exposed to the browser via import.meta.env.VITE_API_BASE_URL.
VITE_API_BASE_URL=http://localhost:8000

# ── Frontend Contract Address ─────────────────────────────────────────────────
# Deployed KiteFuelEscrow address exposed to the Vite frontend.
# Used to build the KiteScan explorer link in the DemoPanel.
# Set to the same value as CONTRACT_ADDRESS after deployment.
VITE_CONTRACT_ADDRESS=

# ── Kite Chain Testnet ────────────────────────────────────────────────────────
# RPC endpoint for Kite Chain testnet.
# Required when deploying with: forge script script/Deploy.s.sol --rpc-url $KITE_RPC_URL
KITE_RPC_URL=https://rpc-testnet.gokite.ai/

# Chain ID for Kite Chain testnet (used for reference / wallet config).
KITE_CHAIN_ID=2368

# Block explorer base URL for Kite Chain testnet.
KITE_EXPLORER_URL=https://testnet.kitescan.ai/

# ── Deployment ────────────────────────────────────────────────────────────────
# Private key of the wallet used to deploy contracts to a live network.
# NEVER commit a funded private key. Use a dedicated throwaway deployer wallet.
# Fund it from https://faucet.gokite.ai before deploying.
DEPLOYER_PRIVATE_KEY=

# Address of the backend signer wallet set as authorizedSigner in KiteFuelEscrow.
# Corresponds to the public address of BACKEND_SIGNER_PRIVATE_KEY.
BACKEND_SIGNER_ADDRESS=
